name = "fic-windows-utilities-counters"
main = "cloudflare-download-counter.js"
compatibility_date = "2026-05-20"

kv_namespaces = [
  { binding = "DOWNLOAD_STATS", id = "PUT_YOUR_KV_NAMESPACE_ID_HERE" }
]

